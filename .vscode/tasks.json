{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-server",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Server/TopdownMMO.sln",
                "--configuration",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "run-client",
            "type": "shell",
            "command": "& 'C:\\Users\\PICHAU\\Downloads\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64.exe' --path '${workspaceFolder}/Client'",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "start-client",
            "dependsOn": [
                "build-server",
                "run-client"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "build-all",
            "dependsOn": [
                "build-server"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
